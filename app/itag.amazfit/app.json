{
  "configVersion": "v3",
  "app": {
    "appId": 20879,  
    "appName": "eL-Finder",
    "appType": "app",
    "version": {
      "code": 1,
      "name": "1.0.0"
    },
    "icon": "icon.png",
    "vender": "eliascn",
    "description": "BLE tag Finder"
  },
  "permissions": [
    "device:os.ble",
    "device:os.local_storage"
  ],
