  "targets": {
    "default": {
      "module": {
        "page": {
          "pages": ["page/index"]
        }
      },
      "platforms": [
        {
          "st": "r", 
          "dw": 480
        },
        {
          "st": "s",
          "dw": 480
        },
        {
          "st": "b",
          "dw": 480
        }
      ]
    }
  },
  "i18n": {
    "en-US": {
      "appName": "eL-Finder"
